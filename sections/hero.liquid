<div
  class="relative w-full lg:h-[calc(100vh-140px)] overflow-hidden"
  style="background-color: {{ section.settings.bg_color }};"
>
  {%- if section.settings.bg_image != blank -%}
    <div
      class="absolute inset-0 w-full h-full opacity-60 z-0 pointer-events-none"
      style="background-image: url('{{ section.settings.bg_image | image_url }}'); background-repeat: repeat; background-position: top left; background-size: auto;"
    ></div>
  {%- endif -%}

  <div class="w-full flex flex-col lg:flex-row items-stretch h-full relative z-10">
    <!-- Left Content -->
    <div class="w-full lg:w-1/2 flex flex-col justify-center px-6 md:px-12 lg:px-24 py-16 lg:py-10 text-[#2d2926]">
      {%- if section.settings.subtitle != blank -%}
        <p class="text-[#cda066] text-xs font-bold tracking-[0.15em] uppercase mb-6">
          {{ section.settings.subtitle | escape }}
        </p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <!-- Using a default text with HTML allowed so users can add spans or break tags -->
        <h1 class="text-4xl md:text-5xl lg:text-[64px] font-serif leading-[1.15] mb-6">
          {{ section.settings.title }}
        </h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="text-[15px] opacity-80 leading-relaxed max-w-[420px] mb-10 text-[#54504e]">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

      <div class="flex flex-wrap gap-4">
        {%- if section.settings.btn1_text != blank -%}
          <a
            href="{{ section.settings.btn1_link }}"
            class="inline-flex items-center justify-center px-8 py-3.5 bg-[#3a3229] hover:bg-[#221d17] text-white text-xs font-bold uppercase tracking-widest transition-colors rounded-sm shadow-sm group"
          >
            {{ section.settings.btn1_text | escape }}
            <svg
              class="w-4 h-4 ml-2.5 transform group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.btn2_text != blank -%}
          <a
            href="{{ section.settings.btn2_link }}"
            class="inline-flex items-center justify-center px-8 py-3.5 bg-white text-[#3a3229] border border-gray-200 text-xs font-bold uppercase tracking-widest hover:bg-gray-50 transition-colors rounded-sm shadow-sm"
          >
            {{ section.settings.btn2_text | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Right Media (Image / Video) -->
    <div class="w-full lg:w-1/2 relative bg-gray-100 min-h-[400px] lg:min-h-full flex-shrink-0 z-10 border-l border-gray-200/60 p-0 m-0">
      {%- if section.settings.video != blank -%}
        <div class="w-full h-full absolute inset-0">
          <!-- native shopify video -->
          {{
            section.settings.video
            | video_tag:
              class: 'w-full h-full object-cover object-center',
              image_size: '1200x',
              autoplay: false,
              loop: true,
              muted: false,
              controls: false,
              id: section.id
          }}
        </div>

        <button
          id="hero-play-btn-{{ section.id }}"
          class="absolute bottom-8 left-8 w-[52px] h-[52px] rounded-full border border-white/60 flex items-center justify-center text-white hover:bg-white/20 transition-all backdrop-blur-sm focus:outline-none z-20 group"
        >
          <svg
            class="w-5 h-5 ml-1 drop-shadow-md group-hover:scale-110 transition-transform"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M4 4l12 6-12 6z"></path>
          </svg>
        </button>

      {%- elsif section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="eager"
          class="w-full h-full object-cover object-center absolute inset-0"
        >
      {%- else -%}
        {{
          'collection-1'
          | placeholder_svg_tag: 'w-full h-full object-cover object-center absolute inset-0 text-gray-400 bg-gray-100'
        }}
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Dynamic Hero Video logic
    const videoElem = document.querySelector('video#{{ section.id }}');
    const playBtn = document.getElementById('hero-play-btn-{{ section.id }}');

    if (videoElem && playBtn) {
      playBtn.addEventListener('click', function () {
        if (videoElem.paused) {
          videoElem.play();
          playBtn.classList.add('opacity-0', 'pointer-events-none');
        }
      });

      videoElem.addEventListener('click', function () {
        if (!videoElem.paused) {
          videoElem.pause();
          playBtn.classList.remove('opacity-0', 'pointer-events-none');
        }
      });

      videoElem.addEventListener('ended', function () {
        playBtn.classList.remove('opacity-0', 'pointer-events-none');
      });
    }
  });
</script>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fbf8f1"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Pattern Image (Optional)",
      "info": "Upload a repeating floral pattern line-art image."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "NEW ARRIVALS - SUMMER 2026"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Artisan fabrics,<br><span style='color: #cda066; font-style: italic;'>thoughtfully</span> curated",
      "info": "HTML is allowed. Use <br> for line breaks and span tags for custom colors/italics."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>Over a century of fine textiles from the heart of Calicut. Handpicked cottons, silks, and more woven into every occasion.</p>"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "header",
      "content": "Media Cover"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Native Shopify Video",
      "info": "Prioritized over Image if both are set."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback / Static Image"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
