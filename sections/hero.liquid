<style>
  @keyframes hero-reveal-up {
    0% {
      opacity: 0;
      transform: translateY(40px) skewY(2deg);
    }
    100% {
      opacity: 1;
      transform: translateY(0) skewY(0);
    }
  }

  @keyframes hero-image-reveal {
    0% {
      opacity: 0;
      transform: scale(1.1) translateX(20px);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateX(0);
    }
  }

  @keyframes hero-fade-in {
    0% {
      opacity: 0;
    }
    100% {
      opacity: var(--pattern-opacity, 1);
    }
  }

  @keyframes hero-fade-in-right {
    0% {
      opacity: 0;
      transform: translateX(30px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .animate-reveal-up {
    opacity: 0;
    animation: hero-reveal-up 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards;
  }

  .animate-image-reveal {
    opacity: 0;
    animation: hero-image-reveal 1.8s cubic-bezier(0.2, 1, 0.3, 1) forwards;
  }

  .animate-bg-fade {
    opacity: 0;
    animation: hero-fade-in 2s ease-out forwards;
  }

  .delay-1 {
    animation-delay: 0.2s;
  }
  .delay-2 {
    animation-delay: 0.4s;
  }
  .delay-3 {
    animation-delay: 0.6s;
  }
  .delay-4 {
    animation-delay: 0.8s;
  }
  .delay-5 {
    animation-delay: 1s;
  }
</style>

<div
  class="relative w-full lg:h-[calc(100vh-140px)] overflow-hidden"
  style="background-color: {{ section.settings.bg_color }};"
>
  {%- if section.settings.bg_image != blank -%}
    {%- assign pattern_opacity = section.settings.bg_pattern_opacity | divided_by: 100.0 -%}
    <div
      class="absolute inset-0 w-full h-full z-0 pointer-events-none animate-bg-fade"
      style="background-image: url('{{ section.settings.bg_image | image_url }}'); background-repeat: repeat; background-position: top left; background-size: auto; --pattern-opacity: {{ pattern_opacity }};"
    ></div>
  {%- endif -%}

  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 w-full flex flex-col lg:flex-row items-stretch h-full relative z-10">
    <!-- Left Content -->
    <div class="w-full lg:w-1/2 flex items-center lg:pr-8 xl:pr-16 py-8 lg:py-0">
      <div class="w-full flex flex-col justify-center text-[#2d2926]">
        {%- if section.settings.subtitle != blank -%}
          <p class="text-[#cda066] text-[11px] font-bold tracking-normal uppercase mb-8 animate-reveal-up delay-1">
            {{ section.settings.subtitle | escape }}
          </p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h1 class="text-4xl md:text-5xl lg:text-[72px] font-serif leading-[1.1] mb-8 [&_em]:italic [&_em]:text-[#cda066] [&_i]:italic [&_i]:text-[#cda066] animate-reveal-up delay-2">
            {{ section.settings.title }}
          </h1>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="text-[16px] opacity-75 leading-relaxed max-w-[460px] mb-12 text-[#54504e] animate-reveal-up delay-3">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        <div class="flex flex-wrap items-center gap-8 animate-reveal-up delay-4">
          {%- if section.settings.btn1_text != blank -%}
            <a
              href="{{ section.settings.btn1_link }}"
              class="inline-flex items-center justify-center px-10 py-4 bg-[#3a3229] hover:bg-[#221d17] text-white text-[11px] font-bold uppercase tracking-normal transition-all rounded-sm shadow-md group"
            >
              {{ section.settings.btn1_text | escape }}
              <svg
                class="w-4 h-4 ml-3 transform group-hover:translate-x-1.5 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.btn2_text != blank -%}
            <a
              href="{{ section.settings.btn2_link }}"
              class="text-[#3a3229] text-[11px] font-bold uppercase tracking-normal border-b border-[#3a3229]/30 hover:border-[#3a3229] transition-all pb-1"
            >
              {{ section.settings.btn2_text | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Right Media (Image / Video) -->
    <div class="w-full lg:w-1/2 relative min-h-[400px] lg:min-h-full flex-shrink-0 z-10 flex flex-col mt-8 lg:mt-0 pb-12 lg:pb-0">
      <div class="w-full h-full relative overflow-hidden flex-grow shadow-2xl animate-image-reveal">
        {%- if section.settings.video != blank -%}
          <div class="w-full h-full absolute inset-0">
            {{
              section.settings.video
              | video_tag:
                class: 'w-full h-full object-cover object-center absolute inset-0 cursor-pointer',
                image_size: '1200x',
                autoplay: true,
                loop: true,
                muted: true,
                controls: false,
                id: section.id
            }}
          </div>

        {%- elsif section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            alt="{{ section.settings.image.alt | escape }}"
            loading="eager"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            class="w-full h-full object-cover object-center absolute inset-0"
          >
        {%- else -%}
          {{
            'collection-1'
            | placeholder_svg_tag: 'w-full h-full object-cover object-center absolute inset-0 text-gray-400 bg-gray-100'
          }}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Dynamic Hero Video logic: Toggle play/pause by clicking the video
    const videoElem = document.querySelector('video#{{ section.id }}');

    if (videoElem) {
      videoElem.addEventListener('click', function () {
        if (videoElem.paused) {
          videoElem.play();
        } else {
          videoElem.pause();
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fbf8f1"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Pattern Image (Optional)",
      "info": "Upload a repeating floral pattern line-art image."
    },
    {
      "type": "range",
      "id": "bg_pattern_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Pattern Opacity",
      "default": 40
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "NEW ARRIVALS - SUMMER 2026"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Artisan fabrics, <em>thoughtfully</em> curated",
      "info": "Highlight text and use the format bar to make words italic automatically."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>Over a century of fine textiles from the heart of Calicut. Handpicked cottons, silks, and more woven into every occasion.</p>"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "header",
      "content": "Media Cover"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Native Shopify Video",
      "info": "Prioritized over Image if both are set."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback / Static Image"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
