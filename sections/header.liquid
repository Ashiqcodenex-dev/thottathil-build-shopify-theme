{%- if section.settings.enable_sticky_header -%}
  <style>
    #shopify-section-{{ section.id }} {
      position: sticky;
      top: 0;
      z-index: 50;
    }
  </style>
  <script>
    // Calculate announcement bar height and offset the sticky section up natively
    // This causes natural scroll offscreen without any layout thrashing (jerking)
    document.addEventListener('DOMContentLoaded', () => {
      const section = document.getElementById('shopify-section-{{ section.id }}');
      const announcement = document.getElementById('announcement-bar-wrapper');
      const updateStickyTop = () => {
        if (section && announcement) {
          section.style.top = `-${announcement.offsetHeight}px`;
        }
      };
      updateStickyTop();
      window.addEventListener('resize', updateStickyTop);
    });
  </script>
{%- endif -%}

{% if section.settings.show_announcement %}
  <div
    id="announcement-bar-wrapper"
    style="background-color: {{ section.settings.announcement_bg_color }}; color: {{ section.settings.announcement_text_color }};"
    class="text-xs py-2.5 px-4 text-center tracking-wider flex justify-center items-center font-medium transition-all duration-300 origin-top overflow-hidden"
  >
    {%- if section.settings.announcement_link != blank -%}
      <a href="{{ section.settings.announcement_link }}" class="hover:underline">
    {%- endif -%}
    {{ section.settings.announcement_text | escape }}
    {%- if section.settings.announcement_link != blank -%}
      </a>
    {%- endif -%}
  </div>
{% endif %}

<div
  id="site-header-wrapper"
  class="relative inset-x-0 w-full z-10 bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100 transition-all duration-500 ease-in-out"
>
  <!-- Main Navbar -->
  <div class="max-w-[100%] px-4 mx-auto">
    <div class="flex justify-between items-center min-h-[90px] py-4">
      <!-- Left: Menu Toggle -->
      <div class="flex items-center flex-1">
        <button
          id="open-menu-btn"
          type="button"
          class="flex items-center text-gray-900 hover:opacity-70 focus:outline-none transition-opacity cursor-pointer"
        >
          <svg
            class="w-5 h-5 mr-2.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <!-- 3-line hamburger icon with bold middle line -->
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M3 6h18M3 18h18"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h18"></path>
          </svg>
          <span class="text-[13px] tracking-wide font-medium hidden sm:block">Menu</span>
        </button>
      </div>

      <!-- Center: Logo -->
      <div class="flex-shrink-0 flex items-center justify-center flex-1">
        <a href="{{ routes.root_url }}" class="block">
          {%- assign desktop_logo = settings.logo -%}
          {%- assign mobile_logo = settings.logo_mobile | default: desktop_logo -%}

          <div id="header-normal-logo" class="transition-opacity duration-300">
            {%- if desktop_logo != blank -%}
              {%- assign logo_alt = desktop_logo.alt | default: shop.name | escape -%}
              <!-- Desktop Logo -->
              <img
                src="{{ desktop_logo | image_url: width: 600 }}"
                alt="{{ logo_alt }}"
                width="{{ desktop_logo.width }}"
                height="{{ desktop_logo.height }}"
                style="max-width: {{ settings.logo_width }}px; height: auto;"
                class="hidden sm:block mx-auto"
                loading="eager"
              >
              <!-- Mobile Logo -->
              <img
                src="{{ mobile_logo | image_url: width: 600 }}"
                alt="{{ logo_alt }}"
                width="{{ mobile_logo.width }}"
                height="{{ mobile_logo.height }}"
                style="max-width: {{ settings.logo_mobile_width }}px; height: auto;"
                class="block sm:hidden mx-auto"
                loading="eager"
              >
            {%- else -%}
              <span class="text-2xl font-bold tracking-tight text-gray-900">{{ shop.name }}</span>
            {%- endif -%}
          </div>

          {%- if section.settings.sticky_logo != blank -%}
            <div
              id="header-sticky-logo"
              class="hidden opacity-0 transition-opacity duration-300 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
            >
              <img
                src="{{ section.settings.sticky_logo | image_url: width: 600 }}"
                alt="{{ section.settings.sticky_logo.alt | default: shop.name | escape }}"
                width="{{ section.settings.sticky_logo.width }}"
                height="{{ section.settings.sticky_logo.height }}"
                style="max-width: {{ section.settings.sticky_logo_width }}px; height: auto;"
                class="inline-block"
                loading="lazy"
              >
            </div>
          {%- endif -%}
        </a>
      </div>

      <!-- Right: Icons -->
      <div class="flex items-center justify-end flex-1 space-x-5 lg:space-x-7">
        <a href="{{ routes.search_url }}" class="text-gray-900 hover:opacity-70 transition-opacity">
          <span class="sr-only">Search</span>
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 21l-4.35-4.35m1.35-5.65a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </a>

        {%- if shop.customer_accounts_enabled -%}
          <a
            href="{{ routes.account_url }}"
            class="text-gray-900 hover:opacity-70 transition-opacity hidden sm:block"
          >
            <span class="sr-only">Account</span>
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </a>
        {%- endif -%}

        <!-- For Cart Icon -->
        <a
          href="{{ routes.cart_url }}"
          class="text-gray-900 hover:opacity-70 transition-opacity relative flex items-center"
        >
          <span class="sr-only">Cart</span>
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span
              class="absolute -top-1 -right-1.5 bg-[#d4af37] w-1.5 h-1.5 rounded-full"
            ></span>
          {%- else -%}
            <span
              class="absolute -top-1 -right-1.5 bg-[#d4af37] w-1.5 h-1.5 rounded-full hidden"
            ></span>
          {%- endif -%}
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Drawer / Sidebar Menu -->
<div
  id="menu-drawer-overlay"
  class="fixed inset-0 bg-black/50 z-[60] hidden transition-opacity duration-300 opacity-30"
></div>

<div
  id="menu-drawer"
  class="fixed top-0 left-0 h-full w-[360px] max-w-[85vw] bg-white z-[70] transform -translate-x-full transition-transform duration-300 shadow-2xl overflow-y-auto flex flex-col"
>
  <div class="flex justify-between items-center px-8 py-6 border-b border-gray-100/60">
    <span class="text-[22px] font-serif italic text-gray-900 tracking-wider">Browse</span>
    <button
      id="close-menu-btn"
      type="button"
      class="text-gray-400 hover:text-gray-800 transition-colors focus:outline-none"
    >
      <span class="sr-only">Close menu</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto py-2 flex flex-col">
    <ul class="flex flex-col">
      {%- for link in section.settings.menu.links -%}
        <li class="border-b border-gray-100/50">
          {%- if link.links != blank -%}
            <button
              type="button"
              class="menu-accordion-btn w-full flex justify-between items-center px-8 py-2 text-[15.5px] font-medium text-gray-900 hover:bg-gray-50 transition-colors tracking-wide"
              aria-expanded="false"
              data-target="submenu-{{ forloop.index }}"
            >
              <span>{{ link.title | escape }}</span>
              <span class="text-gray-400 plus-icon flex items-center">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 4v16m8-8H4"></path>
                </svg>
              </span>
              <span class="text-gray-400 minus-icon hidden flex items-center">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 12h16"></path>
                </svg>
              </span>
            </button>
            <div id="submenu-{{ forloop.index }}" class="hidden bg-white pl-[44px] pr-8 pb-4">
              {%- for childlink in link.links -%}
                {%- if childlink.links != blank -%}
                  <div class="mt-7 mb-3">
                    <h3 class="flex items-center text-[10.5px] text-[#8c6b4a] font-bold tracking-[0.2em] uppercase">
                      {%- if section.settings.child_menu_image != blank -%}
                        <img
                          src="{{ section.settings.child_menu_image | image_url: width: 40 }}"
                          alt="Menu Icon"
                          class="w-4 h-4 mr-2 object-contain"
                          width="16"
                          height="16"
                        >
                      {%- elsif section.settings.child_menu_svg != blank -%}
                        <span class="w-3.5 h-3.5 mr-2 opacity-80 inline-flex items-center justify-center svg-icon-wrapper">
                          {{ section.settings.child_menu_svg }}
                        </span>
                      {%- else -%}
                        <svg class="w-3.5 h-3.5 mr-2 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <!-- Custom Default Textile / Paisley Motif SVG -->
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3c-1.5 0-2.5 1-2.5 2.5 0 2 1 3.5 2.5 5.5 1.5 2 2.5 3.5 1.5 6 0 0 2-2 3-5 1-3 1-5-1-6.5-1-1-1-2.5 1-2.5 1 0 2.5 1.5 2.5 3 0-1-1-1.5-1-2.5 0-1.5-1.5-3-3-3z"></path>
                          <circle cx="12" cy="14" r="1.5" fill="currentColor" stroke="none"></circle>
                        </svg>
                      {%- endif -%}

                      {{ childlink.title | escape }}
                    </h3>
                  </div>
                  <ul class="flex flex-col">
                    {%- for grandchildlink in childlink.links -%}
                      <li>
                        <a
                          href="{{ grandchildlink.url }}"
                          class="block py-[5.5px] text-[14.5px] font-light text-gray-800 hover:text-[#cda066] transition-colors border-b border-gray-100 tracking-wide"
                        >
                          {{ grandchildlink.title | escape }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- else -%}
                  <div class="mt-2">
                    <a
                      href="{{ childlink.url }}"
                      class="block py-[5.5px] text-[14.5px] font-light text-gray-800 hover:text-[#cda066] transition-colors tracking-wide border-b border-gray-100/90"
                    >
                      {{ childlink.title | escape }}
                    </a>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- else -%}
            <a
              href="{{ link.url }}"
              class="block px-8 py-2 text-[15.5px] font-medium {% if link.active %}text-[#cda066]{% else %}text-gray-900 hover:text-gray-600{% endif %} hover:bg-gray-50 transition-colors tracking-wide flex justify-between items-center"
            >
              <span>{{ link.title | escape }}</span>
            </a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    <div class="px-8 mt-auto mb-4 pt-10 flex flex-col space-y-6">
      {%- if section.settings.secondary_menu != blank -%}
        {%- for link in section.settings.secondary_menu.links -%}
          <a
            href="{{ link.url }}"
            class="text-[13px] md:text-sm text-gray-900 hover:text-gray-500 transition-colors tracking-wide font-medium"
          >
            {{ link.title | escape }}
          </a>
        {%- endfor -%}
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        {%- if customer -%}
          <a
            href="{{ routes.account_url }}"
            class="text-[13px] md:text-sm text-gray-900 hover:text-gray-500 transition-colors tracking-wide font-medium"
          >
            Account
          </a>
        {%- else -%}
          <a
            href="{{ routes.account_login_url }}"
            class="text-[13px] md:text-sm text-gray-900 hover:text-gray-500 transition-colors tracking-wide font-medium"
          >
            Log In
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>
  </nav>

  <!-- Drawer Social Links -->
  <div class="px-8 py-6 border-t border-gray-100 flex space-x-4">
    {%- if settings.social_instagram_link != blank -%}
      <a href="{{ settings.social_instagram_link }}" class="text-gray-400 hover:text-[#d4af37] transition-colors">
        <span class="sr-only">Instagram</span>
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
    {%- endif -%}
    {%- if settings.social_facebook_link != blank -%}
      <a href="{{ settings.social_facebook_link }}" class="text-gray-400 hover:text-[#d4af37] transition-colors">
        <span class="sr-only">Facebook</span>
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
        </svg>
      </a>
    {%- endif -%}
    {%- if settings.social_twitter_link != blank -%}
      <a href="{{ settings.social_twitter_link }}" class="text-gray-400 hover:text-[#d4af37] transition-colors">
        <span class="sr-only">Twitter</span>
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const openBtn = document.getElementById('open-menu-btn');
    const closeBtn = document.getElementById('close-menu-btn');
    const drawer = document.getElementById('menu-drawer');
    const overlay = document.getElementById('menu-drawer-overlay');

    function openMenu() {
      overlay.classList.remove('hidden');
      requestAnimationFrame(() => {
        overlay.classList.remove('opacity-0');
        drawer.classList.remove('-translate-x-full');
      });
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      overlay.classList.add('opacity-0');
      drawer.classList.add('-translate-x-full');
      setTimeout(() => {
        overlay.classList.add('hidden');
      }, 300); // Wait for transition
      document.body.style.overflow = '';
    }

    if (openBtn) openBtn.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    if (overlay) overlay.addEventListener('click', closeMenu);

    // Quick escape key close
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && !overlay.classList.contains('hidden')) {
        closeMenu();
      }
    });

    // Accordion Logic
    const accordionBtns = document.querySelectorAll('.menu-accordion-btn');
    accordionBtns.forEach((btn) => {
      btn.addEventListener('click', function () {
        const targetId = this.getAttribute('data-target');
        const targetMenu = document.getElementById(targetId);
        const isExpanded = this.getAttribute('aria-expanded') === 'true';

        if (isExpanded) {
          this.setAttribute('aria-expanded', 'false');
          targetMenu.classList.add('hidden');
          this.querySelector('.plus-icon').classList.remove('hidden');
          this.querySelector('.minus-icon').classList.add('hidden');
        } else {
          this.setAttribute('aria-expanded', 'true');
          targetMenu.classList.remove('hidden');
          this.querySelector('.plus-icon').classList.add('hidden');
          this.querySelector('.minus-icon').classList.remove('hidden');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Sticky Header"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_header",
      "label": "Enable Sticky Header",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "sticky_logo",
      "label": "Sticky Header Logo",
      "info": "Optional alternate logo for when the header is sticky and scrolled."
    },
    {
      "type": "range",
      "id": "sticky_logo_width",
      "min": 50,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Sticky Logo width",
      "default": 140
    },
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Free shipping on orders above ₹999 · Est. 1909 — Calicut"
    },
    {
      "type": "url",
      "id": "announcement_link",
      "label": "Announcement link"
    },
    {
      "type": "color",
      "id": "announcement_bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "announcement_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Menu"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "secondary_menu",
      "label": "Secondary Drawer Menu",
      "info": "This menu appears exactly below the primary browse menu, near the 'Log In' link."
    },
    {
      "type": "header",
      "content": "Child Menu Graphic"
    },
    {
      "type": "image_picker",
      "id": "child_menu_image",
      "label": "Upload SVG/Image File",
      "info": "Choose an image from your files. This will be applied globally to all child menu headings."
    },
    {
      "type": "html",
      "id": "child_menu_svg",
      "label": "Or Paste Raw <svg> Code",
      "info": "Overrides the image upload. Applied globally."
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}

{% if section.settings.enable_sticky_header %}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const headerWrapper = document.getElementById('site-header-wrapper');
      const announcementBar = document.getElementById('announcement-bar-wrapper');
      const normalLogo = document.getElementById('header-normal-logo');
      const stickyLogo = document.getElementById('header-sticky-logo');

      if (headerWrapper) {
        const handleScroll = () => {
          if (window.scrollY > 50) {
            // Scrolled Exact Design
            headerWrapper.classList.remove('bg-white/90', 'border-gray-100', 'shadow-sm', 'backdrop-blur-md');
            headerWrapper.classList.add('bg-white/50', 'backdrop-blur-3xl', 'border-gray-200/50', 'shadow-md');

            if (normalLogo && stickyLogo) {
              normalLogo.classList.add('opacity-0');
              setTimeout(() => {
                if (window.scrollY > 50) {
                  normalLogo.classList.add('hidden');
                  stickyLogo.classList.remove('hidden');
                  setTimeout(() => stickyLogo.classList.remove('opacity-0'), 10);
                }
              }, 150);
            }
          } else {
            // Initial Design
            headerWrapper.classList.add('bg-white/90', 'border-gray-100', 'shadow-sm', 'backdrop-blur-md');
            headerWrapper.classList.remove('bg-white/50', 'backdrop-blur-3xl', 'border-gray-200/50', 'shadow-md');

            if (normalLogo && stickyLogo) {
              stickyLogo.classList.add('opacity-0');
              setTimeout(() => {
                if (window.scrollY <= 50) {
                  stickyLogo.classList.add('hidden');
                  normalLogo.classList.remove('hidden');
                  setTimeout(() => normalLogo.classList.remove('opacity-0'), 10);
                }
              }, 150);
            }
          }
        };

        window.addEventListener('scroll', handleScroll, { passive: true });
        handleScroll(); // Init
      }
    });
  </script>
{% endif %}
