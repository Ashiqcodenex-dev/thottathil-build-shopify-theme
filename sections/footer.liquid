<footer
  style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
  class="pt-16 pb-8"
>
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12">
    <!-- Top Footer Columns -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8 mb-16">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'info' -%}
            <div class="lg:col-span-2 flex flex-col space-y-8 pr-0 lg:pr-10" {{ block.shopify_attributes }}>
              {%- if block.settings.logo != blank -%}
                <a href="{{ routes.root_url }}" class="inline-block">
                  <img
                    src="{{ block.settings.logo | image_url: width: 400 }}"
                    alt="{{ block.settings.logo.alt | default: shop.name | escape }}"
                    width="{{ block.settings.logo.width }}"
                    height="{{ block.settings.logo.height }}"
                    style="max-width: {{ block.settings.logo_width }}px; height: auto;"
                    loading="lazy"
                  >
                </a>
              {%- else -%}
                <!-- Fallback to global footer logo or theme desktop logo -->
                {%- assign fallback_logo = settings.logo -%}
                {%- if fallback_logo != blank -%}
                  <a href="{{ routes.root_url }}" class="inline-block">
                    <img
                      src="{{ fallback_logo | image_url: width: 400 }}"
                      alt="{{ fallback_logo.alt | default: shop.name | escape }}"
                      width="{{ fallback_logo.width }}"
                      height="{{ fallback_logo.height }}"
                      style="max-width: {{ block.settings.logo_width }}px; height: auto;"
                      loading="lazy"
                    >
                  </a>
                {%- else -%}
                  <h2 class="text-2xl font-serif text-white">{{ shop.name }}</h2>
                {%- endif -%}
              {%- endif -%}

              <div class="space-y-6 text-[13px] opacity-80 leading-relaxed max-w-sm">
                {%- if block.settings.about_text != blank -%}
                  <div class="prose-p:m-0">{{ block.settings.about_text }}</div>
                {%- endif -%}

                {%- if block.settings.address_text != blank -%}
                  <div class="prose-p:m-0">{{ block.settings.address_text }}</div>
                {%- endif -%}

                {%- if block.settings.contact_text != blank -%}
                  <div class="prose-p:m-0">{{ block.settings.contact_text }}</div>
                {%- endif -%}
              </div>
            </div>

          {%- when 'link_list' -%}
            <div class="flex flex-col space-y-6" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="text-xs tracking-[0.15em] uppercase font-bold text-white">
                  {{ block.settings.heading | escape }}
                </h3>
              {%- endif -%}

              {%- if block.settings.menu != blank -%}
                <ul class="space-y-4 text-[13px] opacity-80">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li>
                      <a href="{{ link.url }}" class="hover:text-white hover:opacity-100 transition-colors">
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- else -%}
                <!-- Fallback menu placeholder for customizer -->
                <ul class="space-y-4 text-[13px] opacity-80">
                  <li><a href="#" class="hover:text-white hover:opacity-100 transition-colors">Example link 1</a></li>
                  <li><a href="#" class="hover:text-white hover:opacity-100 transition-colors">Example link 2</a></li>
                  <li><a href="#" class="hover:text-white hover:opacity-100 transition-colors">Example link 3</a></li>
                </ul>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <!-- Bottom Footer border & Copyright -->
    <div class="border-t border-gray-600/30 pt-8 flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0 text-xs opacity-70">
      <div>
        &copy; {{ 'now' | date: '%Y' }}
        {{ section.settings.copyright_text | default: shop.name | escape }}
      </div>

      {%- if section.settings.show_social -%}
        <div class="flex space-x-6 tracking-widest uppercase">
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" class="hover:text-white transition-colors hover:opacity-100"
              >Facebook</a
            >
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="hover:text-white transition-colors hover:opacity-100"
              >Instagram</a
            >
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
            <a href="{{ settings.social_twitter_link }}" class="hover:text-white transition-colors hover:opacity-100"
              >Twitter</a
            >
          {%- endif -%}
          {%- if settings.social_youtube_link != blank -%}
            <a href="{{ settings.social_youtube_link }}" class="hover:text-white transition-colors hover:opacity-100"
              >YouTube</a
            >
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1a1614"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#d1d1d1"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Thottathil Silks & Cottons LLP"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    }
  ],
  "max_blocks": 5,
  "blocks": [
    {
      "type": "info",
      "name": "Store Info",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Footer Logo"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50,
          "max": 300,
          "step": 5,
          "unit": "px",
          "label": "Logo width",
          "default": 140
        },
        {
          "type": "richtext",
          "id": "about_text",
          "label": "About text",
          "default": "<p>A century of artisan textiles from the heart of Calicut — fabrics curated with love and tradition.</p>"
        },
        {
          "type": "richtext",
          "id": "address_text",
          "label": "Address",
          "default": "<p>Stadium Plaza, Pavamani Road Junction<br>Calicut - 673004, Kerala</p>"
        },
        {
          "type": "richtext",
          "id": "contact_text",
          "label": "Contact numbers",
          "default": "<p>8086009944<br>0495 272 1610</p>"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "info"
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "SHOP"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "HELP"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "CONNECT"
          }
        }
      ]
    }
  ]
}
{% endschema %}
