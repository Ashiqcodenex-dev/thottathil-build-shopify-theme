<footer
  style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
  class="pt-16 pb-8"
>
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12">
    <!-- Top Footer Columns -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8 mb-16">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'info' -%}
            <div class="lg:col-span-2 flex flex-col space-y-8 pr-0 lg:pr-10" {{ block.shopify_attributes }}>
              {%- if block.settings.logo != blank -%}
                <a href="{{ routes.root_url }}" class="inline-block">
                  <img
                    src="{{ block.settings.logo | image_url: width: 400 }}"
                    alt="{{ block.settings.logo.alt | default: shop.name | escape }}"
                    width="{{ block.settings.logo.width }}"
                    height="{{ block.settings.logo.height }}"
                    style="max-width: {{ block.settings.logo_width }}px; height: auto;"
                    loading="lazy"
                  >
                </a>
              {%- else -%}
                <!-- Fallback to global footer logo or theme desktop logo -->
                {%- assign fallback_logo = settings.logo -%}
                {%- if fallback_logo != blank -%}
                  <a href="{{ routes.root_url }}" class="inline-block">
                    <img
                      src="{{ fallback_logo | image_url: width: 400 }}"
                      alt="{{ fallback_logo.alt | default: shop.name | escape }}"
                      width="{{ fallback_logo.width }}"
                      height="{{ fallback_logo.height }}"
                      style="max-width: {{ block.settings.logo_width }}px; height: auto;"
                      loading="lazy"
                    >
                  </a>
                {%- else -%}
                  <h2 class="text-2xl font-serif text-white">{{ shop.name }}</h2>
                {%- endif -%}
              {%- endif -%}

              <div class="space-y-6 text-[13px] leading-relaxed max-w-sm">
                {%- if block.settings.about_text != blank -%}
                  <div class="prose-p:m-0 text-white/70">{{ block.settings.about_text }}</div>
                {%- endif -%}

                {%- if block.settings.address_text != blank -%}
                  <div class="prose-p:m-0 text-white/70">{{ block.settings.address_text }}</div>
                {%- endif -%}

                {%- if block.settings.contact_text != blank -%}
                  <div class="prose-p:m-0 text-[#B09878] font-medium tracking-wider">
                    {{ block.settings.contact_text }}
                  </div>
                {%- endif -%}
              </div>
            </div>

          {%- when 'link_list' -%}
            <div class="flex flex-col space-y-6" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="text-xs tracking-[0.15em] uppercase font-bold text-[#E2DDD8]">
                  {{ block.settings.heading | escape }}
                </h3>
              {%- endif -%}

              {%- if block.settings.menu != blank -%}
                <ul class="space-y-4 text-[13px] text-[#E6D8D0]/50">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li>
                      <a href="{{ link.url }}" class="hover:text-white transition-colors">
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- else -%}
                <!-- Fallback menu placeholder for customizer -->
                <ul class="space-y-4 text-[13px] text-[#E6D8D0]/50">
                  <li><a href="#" class="hover:text-white transition-colors">Example link 1</a></li>
                  <li><a href="#" class="hover:text-white transition-colors">Example link 2</a></li>
                  <li><a href="#" class="hover:text-white transition-colors">Example link 3</a></li>
                </ul>
              {%- endif -%}
            </div>

          {%- when 'connect' -%}
            <div class="flex flex-col space-y-6" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="text-xs tracking-[0.15em] uppercase font-bold text-[#E2DDD8] mb-2">
                  {{ block.settings.heading | escape }}
                </h3>
                <br>
              {%- endif -%}

              <!-- Social SVGs -->
              <div class="flex items-center space-x-3">
                {%- if block.settings.icon_1 != blank or block.settings.link_1 != blank -%}
                  <a
                    href="{{ block.settings.link_1 | default: '#' }}"
                    class="w-[34px] h-[34px] flex items-center justify-center rounded-full transition-colors"
                  >
                    {%- if block.settings.icon_1 != blank -%}
                      <img
                        src="{{ block.settings.icon_1 | image_url: width: 40 }}"
                        alt="Social"
                        width="40"
                        height="40"
                        class="w-8 h-8 object-contain opacity-90 hover:opacity-100"
                      >
                    {%- endif -%}
                  </a>
                {%- endif -%}
                {%- if block.settings.icon_2 != blank or block.settings.link_2 != blank -%}
                  <a
                    href="{{ block.settings.link_2 | default: '#' }}"
                    class="w-[34px] h-[34px] flex items-center justify-center rounded-full transition-colors"
                  >
                    {%- if block.settings.icon_2 != blank -%}
                      <img
                        src="{{ block.settings.icon_2 | image_url: width: 40 }}"
                        alt="Social"
                        width="40"
                        height="40"
                        class="w-8 h-8 object-contain opacity-90 hover:opacity-100"
                      >
                    {%- endif -%}
                  </a>
                {%- endif -%}
                {%- if block.settings.icon_3 != blank or block.settings.link_3 != blank -%}
                  <a
                    href="{{ block.settings.link_3 | default: '#' }}"
                    class="w-[34px] h-[34px] flex items-center justify-center rounded-full transition-colors"
                  >
                    {%- if block.settings.icon_3 != blank -%}
                      <img
                        src="{{ block.settings.icon_3 | image_url: width: 40 }}"
                        alt="Social"
                        width="40"
                        height="40"
                        class="w-8 h-8 object-contain opacity-90 hover:opacity-100"
                      >
                    {%- endif -%}
                  </a>
                {%- endif -%}
              </div>
              <!-- My Account Link under social -->
              {%- if shop.customer_accounts_enabled -%}
                <div class="pt-2">
                  <a
                    href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
                    class="text-[14px] text-white opacity-60 hover:opacity-100 transition-opacity tracking-wide"
                  >
                    My Account
                  </a>
                </div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <!-- Bottom Footer border & Copyright -->
    <div class="border-t border-white/10 mt-6 pt-8 flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0 text-[11px] text-[#E6D8D0]/50">
      <div>
        &copy; {{ 'now' | date: '%Y' }}
        {{ section.settings.copyright_text | default: shop.name | escape }}
      </div>

      <div class="tracking-wide">
        woven by
        <a href="https://codenex.in" target="_blank" class="text-[#E6D8D0] font-medium ml-1 text-xs">codenex</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#d1d1d1"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Thottathil Silks & Cottons LLP"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    }
  ],
  "max_blocks": 5,
  "blocks": [
    {
      "type": "info",
      "name": "Store Info",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Footer Logo"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50,
          "max": 300,
          "step": 5,
          "unit": "px",
          "label": "Logo width",
          "default": 140
        },
        {
          "type": "richtext",
          "id": "about_text",
          "label": "About text",
          "default": "<p>A century of artisan textiles from the heart of Calicut — fabrics curated with love and tradition.</p>"
        },
        {
          "type": "richtext",
          "id": "address_text",
          "label": "Address",
          "default": "<p>Stadium Plaza, Pavamani Road Junction<br>Calicut - 673004, Kerala</p>"
        },
        {
          "type": "richtext",
          "id": "contact_text",
          "label": "Contact numbers",
          "default": "<p>8086009944<br>0495 272 1610</p>"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "connect",
      "name": "Connect Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "CONNECT"
        },
        {
          "type": "image_picker",
          "id": "icon_1",
          "label": "Icon 1 (SVG)"
        },
        {
          "type": "url",
          "id": "link_1",
          "label": "Link 1"
        },
        {
          "type": "image_picker",
          "id": "icon_2",
          "label": "Icon 2 (SVG)"
        },
        {
          "type": "url",
          "id": "link_2",
          "label": "Link 2"
        },
        {
          "type": "image_picker",
          "id": "icon_3",
          "label": "Icon 3 (SVG)"
        },
        {
          "type": "url",
          "id": "link_3",
          "label": "Link 3"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Bottom Sub-Menu",
          "info": "Useful for attaching 'My Account' or additional links under socials."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "info"
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "SHOP"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "HELP"
          }
        },
        {
          "type": "connect",
          "settings": {
            "heading": "CONNECT"
          }
        }
      ]
    }
  ]
}
{% endschema %}
