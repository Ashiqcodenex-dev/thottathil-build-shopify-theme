<div class="py-20 px-4 md:px-8 lg:px-12" style="background-color: {{ section.settings.bg_color }};">
  <div class="max-w-[1440px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      {%- if section.settings.subtitle != blank -%}
        <p class="text-[#cda066] text-xs font-bold tracking-[0.25em] uppercase mb-5">
          {{ section.settings.subtitle | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="text-3xl md:text-4xl lg:text-[48px] font-serif text-[#2d2926] leading-tight">
          {{ section.settings.title | escape }}
        </h2>
      {%- endif -%}
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 overflow-hidden">
      {%- for block in section.blocks -%}
        {%- capture grid_class -%}
          {%- case forloop.index -%}
            {%- when 1 -%}
              lg:row-span-2 aspect-[4/5] lg:aspect-auto
            {%- else -%}
              aspect-[4/3]
          {%- endcase -%}
        {%- endcapture -%}

        <div
          class="relative group overflow-hidden rounded-[4px] bg-gray-50 {{ grid_class }}"
          {{ block.shopify_attributes }}
        >
          <a href="{{ block.settings.link }}" class="block w-full h-full">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.image.alt | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                loading="lazy"
              >
            {%- else -%}
              {{
                'collection-'
                | append: forloop.index
                | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-100 transition-transform duration-1000 group-hover:scale-105'
              }}
            {%- endif -%}

            <!-- Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent flex flex-col justify-end p-8 lg:p-10">
              {%- if block.settings.title != blank -%}
                <h3 class="text-white text-2xl lg:text-[28px] font-serif mb-2.5">
                  {{ block.settings.title | escape }}
                </h3>
              {%- endif -%}
              <span class="text-white font-medium text-[11px] tracking-widest uppercase border-b border-white/50 pb-0.5 inline-block w-fit">
                SHOP NOW &rarr;
              </span>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fbf8f1"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "BROWSE BY CATEGORY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What are you looking for?"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        {
          "type": "category",
          "settings": { "title": "Fabrics" }
        },
        {
          "type": "category",
          "settings": { "title": "Sarees" }
        },
        {
          "type": "category",
          "settings": { "title": "Salwars" }
        },
        {
          "type": "category",
          "settings": { "title": "Dupattas" }
        },
        {
          "type": "category",
          "settings": { "title": "Bags" }
        }
      ]
    }
  ]
}
{% endschema %}
