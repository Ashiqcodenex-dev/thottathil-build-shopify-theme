<div class="w-full border-b border-gray-200 overflow-hidden" style="background-color: {{ section.settings.bg_color }};">
  <div class="py-4 flex whitespace-nowrap marquee-container">
    <div class="marquee-content flex items-center">
      {%- if section.settings.menu != blank -%}
        {%- for i in (1..4) -%}
          {%- for link in linklists[section.settings.menu].links -%}
            <div class="flex items-center space-x-6 lg:space-x-12 px-3 lg:px-6 group">
              <a
                href="{{ link.url }}"
                class="text-[10px] md:text-xs font-bold uppercase tracking-[0.15em] text-[#54504e] hover:text-[#cda066] transition-colors whitespace-nowrap"
              >
                {{ link.title | escape }}
              </a>

              <!-- Separator Icon (Small flower/mandala style) -->
              <div class="text-gray-300 w-3 h-3 flex items-center justify-center opacity-60">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-full h-full">
                  <path d="M12 2C12.5523 2 13 2.44772 13 3V6.26795C14.7876 5.61765 16.7121 5.48514 18.5714 5.92211L19.5367 6.14865L17.9048 8.97434C17.0763 10.4093 15.6521 11.4589 13.9877 11.9079C13.9959 11.9382 14 11.9689 14 12C14 13.1046 13.1046 14 12 14C10.8954 14 10 13.1046 10 12C10 11.9689 10.0041 11.9382 10.0123 11.9079C8.34794 11.4589 6.9237 10.4093 6.09519 8.97434L4.4633 6.14865L5.42858 5.92211C7.28789 5.48514 9.21245 5.61765 11 6.26795V3C11 2.44772 11.4477 2 12 2ZM5.28189 18.1568C4.85694 18.5134 4.22359 18.4578 3.86701 18.0329L2.34863 16.2238L5.27552 14.8967C6.76219 14.2222 8.4414 14.2882 9.87635 15.0592C9.85108 15.0863 9.82772 15.115 9.80631 15.1452L8.14083 17.4912C7.30612 18.667 6.00288 19.3879 4.54519 19.4975L1.51654 19.7252L3.10777 17.2023C3.9161 15.9197 5.18431 15.0118 6.643 14.717V14.7176C6.67134 14.7118 6.70014 14.7073 6.72935 14.7041L9.12574 14.4371C10.5186 14.2819 11.9037 14.672 13.0016 15.5332L15.352 17.3768L12.4251 18.7039C10.9384 19.3785 9.25923 19.3125 7.82428 18.5415C7.84954 18.5144 7.87291 18.4857 7.89432 18.4555L9.55981 16.1095C10.3945 14.9337 11.6978 14.2128 13.1554 14.1031L16.1841 13.8755L14.5929 16.3984C13.7845 17.681 12.5163 18.5889 11.0576 18.8837V18.8831C11.0293 18.8889 11.0005 18.8934 10.9713 18.8966L8.57489 19.1636C7.18205 19.3188 5.79689 18.9287 4.69897 18.0675L2.34863 16.2238L3.86701 18.0329C4.22359 18.4578 4.85694 18.5134 5.28189 18.1568Z"></path>
                </svg>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback if no menu selected -->
        {%- for i in (1..4) -%}
          {%- assign fallback_titles = 'ORGANZA,TUSSAR SILK,LINEN,BLOCK PRINT COTTON,CHANDERI SILK,MULMUL COTTON'
            | split: ','
          -%}
          {%- for title in fallback_titles -%}
            <div class="flex items-center space-x-6 lg:space-x-12 px-3 lg:px-6">
              <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.15em] text-[#54504e]">
                {{- title -}}
              </span>
              <div class="text-gray-300 w-3 h-3">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <circle cx="12" cy="12" r="6" />
                </svg>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  /* Fades edges for purely aesthetic reasons like high-end websites */
  .marquee-container {
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }

  .marquee-content {
    display: flex;
    /* Speed is dynamically controlled from theme customizer */
    animation: marquee-scroll {{ section.settings.scroll_speed }}s linear infinite;
  }

  /* Pause animation on hover */
  .marquee-container:hover .marquee-content {
    animation-play-state: paused;
  }

  /* Since we duplicate 4 times, shifting by exactly 50% guarantees a seamless loop */
  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

{% schema %}
{
  "name": "Category Marquee",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Category Menu",
      "info": "Select a menu to display all the categories automatically inside the infinite slider."
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "sec",
      "label": "Scroll speed",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Category Marquee"
    }
  ]
}
{% endschema %}
